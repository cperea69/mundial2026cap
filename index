// M2 Table con imágenes
const maxGoals=Math.max(...M2_DATA.map(d=>d.avg_total));
const tbody=document.getElementById('m2-tbody');
M2_DATA.forEach((d,i)=>{
  const pct=(d.avg_total/maxGoals*100).toFixed(1);
  const topClass=i<3?'top3':'';
  const flagUrl=M2_FLAGS[d.team]||'';
  const flagHtml=flagUrl?`<img src="${flagUrl}" alt="${d.team}" class="flag-img" onerror="this.style.display='none'">`:'';
  tbody.innerHTML+=`
  <tr>
    <td><span class="rank-num ${topClass}">${i+1}</span></td>
    <td>${flagHtml}<strong>${d.team}</strong></td>
    <td>${d.avg_home.toFixed(2)}</td>
    <td>${d.avg_away.toFixed(2)}</td>
    <td><span class="score-num">${d.avg_total.toFixed(2)}</span></td>
    <td><div class="bar-bg"><div class="bar-fill" style="width:${pct}%"></div></div></td>
    <td style="color:#888;font-size:.82rem">${d.games}</td>
  </tr>`;
});

// Match cards con imágenes de banderas
function resultClass(r){return r==='Gana Local'?'local':r==='Gana Visitante'?'visit':'draw'}
function resultLabel(r){return r==='Gana Local'?'Victoria Local':r==='Gana Visitante'?'Victoria Visitante':'Empate'}

function flagImg(url,name,size){
  if(!url) return '';
  return `<img src="${url}" alt="${name}" style="height:${size}px;width:auto;border:1px solid #eee;display:block;margin:0 auto 2px" onerror="this.style.display='none'">`;
}

function renderMatches(filter){
  const grid=document.getElementById('match-grid');
  grid.innerHTML='';
  MATCHES.filter(m=>{
    if(filter==='all') return true;
    if(filter==='local') return m.result==='Gana Local';
    if(filter==='visit') return m.result==='Gana Visitante';
    if(filter==='draw') return m.result==='Empate';
    return true;
  }).forEach(m=>{
    const rc=resultClass(m.result);
    const rl=resultLabel(m.result);
    const dt=new Date(m.date).toLocaleDateString('es-ES',{day:'numeric',month:'long',year:'numeric'});
    const p1ok=m.p1===m.result,p3ok=m.p3===m.result,p4ok=m.p4===m.result;
    const winnerFlagHtml=m.winner_flag_url
      ?`<img src="${m.winner_flag_url}" alt="${m.winner}" style="height:18px;width:auto;border:1px solid #ddd" onerror="this.style.display='none'">`:'';
    grid.innerHTML+=`
    <div class="match-card" data-result="${rc}">
      <div class="match-date">📅 ${dt}</div>
      <div class="match-teams">
        <div class="team-side">
          ${flagImg(m.home_flag_url,m.home,36)}
          <div class="team-name">${m.home}</div>
        </div>
        <div class="score-center">
          <div class="score-display">${m.gl} – ${m.gv}</div>
          <div class="vs-sep">marcador pred.</div>
          <div class="model-votes">
            <div class="vote-dot ${p1ok?'':'disagree'}" title="M1: ${m.p1}"></div>
            <div class="vote-dot ${p3ok?'':'disagree'}" title="M3: ${m.p3}"></div>
            <div class="vote-dot ${p4ok?'':'disagree'}" title="M4: ${m.p4}"></div>
          </div>
        </div>
        <div class="team-side">
          ${flagImg(m.away_flag_url,m.away,36)}
          <div class="team-name">${m.away}</div>
        </div>
      </div>
      <div class="match-footer">
        <div class="winner-label">
          ${winnerFlagHtml} ${m.winner}
        </div>
        <div style="display:flex;gap:.5rem;align-items:center;">
          ${m.risky?'<span class="risky-badge">⚡ Arriesgado</span>':''}
          <span class="consensus-badge ${rc}">${rl}</span>
        </div>
      </div>
    </div>`;
  });
}

renderMatches('all');
function filterMatches(f,btn){
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderMatches(f);
}
</script>
