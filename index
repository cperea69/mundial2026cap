const tKeys=Object.keys(TOUR_DATA);
const tSorted=tKeys.map((k,i)=>([k,+(TOUR_DATA[k].avg_home+TOUR_DATA[k].avg_away).toFixed(2)])).sort((a,b)=>b[1]-a[1]);
new Chart(document.getElementById('chartTournament'),{
  type:'bar',
