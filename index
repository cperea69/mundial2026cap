      {label:'Real (%)',data:[D.pct_local,D.pct_visit,D.pct_empate],backgroundColor:BLACK,borderRadius:2},
      {label:'M1 predicho (%)',data:[D.pp_local,D.pp_visit,D.pp_empate],backgroundColor:BLUE,borderRadius:2}
    ]},
  options:{responsive:true,plugins:{legend:{position:'bottom'}},scales:{y:{grid:{color:'#f0f0f0'},ticks:{callback:v=>v+'%'}}}}
});

new Chart(document.getElementById('chartGoals'),{
  type:'bar',
  data:{labels:['Local (histórico)','Visit. (histórico)','Local (pred. M2)','Visit. (pred. M2)'],
    datasets:[{data:[D.avg_home_hist,D.avg_away_hist,D.avg_home_pred,D.avg_away_pred],
